# ── Frontend env (Vite) ─────────────────────────────────────────────────────
#
# LOCAL DEV
#   Browser → VITE_API_BASE_URL (usually http://localhost:8000) for all NCAA data:
#   teams, matchups, bracket, results cache, scoreboard proxy, model stats.
#   Odds lines → The Odds API when VITE_ODDS_API_KEY is set (else mock odds).
#
# PRODUCTION (e.g. Vercel + Render)
#   Browser → your Render HTTPS API (set VITE_API_BASE_URL at build time).
#   If unset, the app defaults to localhost and production will look "broken" or empty.
#   First load after sleep: Render cold start can take 30s–minutes unless you use
#   committed model pickles + SKIP_MASSEY_ORDINALS_API on the API (see repo .env.example).
#
# Backend API (FastAPI). Required in production on Vercel.
# https://your-api.onrender.com  (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# The Odds API — NCAA basketball (optional; mock odds used if unset)
# https://the-odds-api.com/
VITE_ODDS_API_KEY=3f057b67b82f1e378a815ab431fc0777


