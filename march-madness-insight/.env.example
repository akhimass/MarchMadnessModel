# Backend API (FastAPI). Required in production on Vercel.
# Set to your Render URL (https, no trailing slash), e.g. https://your-api.onrender.com
# Without this, the built app calls http://localhost:8000 and no data loads in the browser.
VITE_API_BASE_URL=http://localhost:8000

# The Odds API — NCAA basketball (optional; mock odds used if unset)
# https://the-odds-api.com/
VITE_ODDS_API_KEY=
