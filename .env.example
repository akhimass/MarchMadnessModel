# Backend (FastAPI / narrative)
ANTHROPIC_API_KEY=
DATA_DIR=./data

# ── Why deploy feels slow vs local ───────────────────────────────────────────
# Local:  API on same machine, no TLS, no cold start; pipeline may already be warm.
# Render: Free tier sleeps → first request wakes the dyno; then load_data + build_features
#         + (optional) train() run before ready_m. Without pickles, training can take many minutes.
# Fix:    Commit artifacts/*.pkl, set paths below, and SKIP_MASSEY_ORDINALS_API=1.
#         Use render.yaml healthCheckPath=/api/health; prefer 1 uvicorn worker so only one
#         process loads the pipeline (see render.yaml startCommand).

# Fast startup on deploy (Render): train once locally, commit artifacts/*.pkl, then set paths.
# python scripts/export_models_for_deploy.py
# STANDARD_MODEL_PATH=./artifacts/standard.pkl
# CHAOS_MODEL_PATH=./artifacts/chaos.pkl

# CORS — comma-separated origins for your Vercel frontend (required for browser → API)
# CORS_ORIGINS=https://your-app.vercel.app

# Deploy: set to 1 to skip loading MMasseyOrdinals.csv at API boot (much faster on Render)
# SKIP_MASSEY_ORDINALS_API=1

# Frontend (Vite) — VITE_API_BASE_URL lives in march-madness-insight/.env for local dev
# and must be set on Vercel to your Render API URL (https, no trailing slash).
VITE_ODDS_API_KEY=
